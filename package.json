{
  "name": "eidon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx esbuild lib/ws-handler.ts --bundle --platform=node --format=cjs --packages=external --outfile=ws-handler-compiled.cjs && node server.cjs",
    "dev:next": "next dev",
    "dev:ws": "npx esbuild lib/ws-handler.ts --bundle --platform=node --format=cjs --packages=external --outfile=ws-handler-compiled.cjs && node server.cjs",
    "build": "next build",
    "start": "npx esbuild lib/ws-handler.ts --bundle --platform=node --format=cjs --packages=external --outfile=ws-handler-compiled.cjs && NODE_ENV=production node server.cjs",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@github/copilot-sdk": "^0.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gpt-tokenizer": "^3.4.0",
    "jose": "^6.0.8",
    "lucide-react": "^0.511.0",
    "next": "15.5.14",
    "openai": "^5.10.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.5.5",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.1.1",
    "autoprefixer": "^10.4.20",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.5.14",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
